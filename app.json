{
  "expo": {
    "name": "Renegade Millionaire",
    "slug": "renegade-millionaire-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "renegademillionaireapp",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "co.brassballs.renegademillionaire",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1210",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "co.brassballs.renegademillionaire",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f1210"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#d5a84c",
          "defaultChannel": "renegade-millionaire"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
